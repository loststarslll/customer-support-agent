# DeepSeek
DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Embedding
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_LOCAL_ONLY=false

# API / UI
API_BASE_URL=http://127.0.0.1:8000
DEFAULT_USER_ID=user_001

# Retrieval
RETRIEVAL_TOP_K=3
RETRIEVAL_THRESHOLD=0.9
FAQ_MAX_RETRIES=1

# Mock data
MOCK_ORDERS_PATH=data/mock/orders.json

# Hybrid retrieval
RAG_RETRIEVER_MODE=hybrid
VECTOR_TOP_K=5
BM25_TOP_K=5
HYBRID_FINAL_TOP_K=3
RRF_K=60
FAQ_CSV_PATH=data/raw/customer_support_faq.csv

# Reranker
RERANKER_ENABLED=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-base
RERANKER_LOCAL_ONLY=false
RERANKER_TOP_K=3

# Query rewrite and references
QUERY_REWRITE_ENABLED=true
SHOW_REFERENCE_SOURCES=true
